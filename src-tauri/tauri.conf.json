{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OrbitKey",
  "version": "0.1.3",
  "identifier": "com.orbitkey.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OrbitKey — Control Panel",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true,
        "skipTaskbar": false
      },
      {
        "label": "action-ring",
        "title": "OrbitKey — Action Ring",
        "acceptFirstMouse": true,
        "width": 800,
        "height": 800,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "center": false,
        "shadow": false,
        "focus": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/ChampMo/orbitkey-releases/refs/heads/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGRUYwQ0FBOTcyMkZGMTUKUldRVi95S1hxZ3p2ajJDNzQ4TEo2cVJpYVhHaW9Wd3JXaTVYeklVbWVoSVVyV0szbzBnbjN6RTYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true, 
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}